# ─── Mash Lead Scrapping — Environment Variables ─────────────────────────────
# Copy to .env and fill in values before running

# ─── API ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://webminer:webminer_secret@localhost:5432/webminer
MASH_DATABASE_URL=postgresql://webminer:webminer_secret@localhost:5432/webminer
# DB_SSL=false  # set to true in production

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:webminer_redis@localhost:6379
MASH_REDIS_URL=redis://:webminer_redis@localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=webminer_redis
# REDIS_DB=0

# ─── Auth ─────────────────────────────────────────────────────────────────────
# GENERATE IN PROD: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-secret-change-in-production-to-a-64-char-random-string
JWT_EXPIRY=7d

# ─── Storage (MinIO / S3) ─────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=webminer
MINIO_SECRET_KEY=webminer_minio
MINIO_BUCKET=webminer-storage

# For AWS S3 in production:
# MINIO_ENDPOINT=s3.amazonaws.com
# MINIO_USE_SSL=true
# MINIO_ACCESS_KEY=your-aws-key
# MINIO_SECRET_KEY=your-aws-secret
# MINIO_BUCKET=your-bucket-name

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:8080

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
DOCKER_SOCKET=/var/run/docker.sock
STORAGE_PATH=.mash-runtime/storage
DOCKER_NETWORK=mash_lead_scrapping_network
API_URL=http://localhost:3000

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_TOKEN=internal-scheduler-token

# ─── Proxy (optional) ─────────────────────────────────────────────────────────
# DEFAULT_PROXY_URL=http://user:pass@proxy-host:8080

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_ANON=100
RATE_LIMIT_MAX_AUTH=1000

# ─── Dashboard ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
MASH_APP_NAME=Mash Lead Scrapping
MASH_PUBLIC_URL=https://mash-lead-scrapping.com
